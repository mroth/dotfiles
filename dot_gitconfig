# include org specific directives based on location.
# https://git-scm.com/docs/git-config#_conditional_includes
# could also use "hasconfig:remote.*.url" vs directory path based.

[includeIf "gitdir:~/src/protocol/"]
	path = ~/src/protocol/.gitconfig.inc

[includeIf "gitdir:~/src/dojo/"]
    path = ~/src/dojo/.gitconfig.inc
