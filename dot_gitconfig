[user]
	name = Matthew Rothenberg
	email = mroth@mroth.xyz
	signingkey = /Users/mroth/.ssh/id_ed25519.pub

[github]
	user = mroth

[gpg]
	format = ssh

# automatically sign all commits
[commit]
	gpgsign = true

# Enable *local* SSH signature verification
# TODO: Need to automate populating the allowed_signers file.
# [gpg "ssh"]
# 	allowedSignersFile = ~/.config/git/allowed_signers

[core]
	excludesfile = ~/.gitignore
	quotepath = false

[init]
	defaultBranch = main

[rebase]
	autosquash = true
	autostash = true

[push]
	autoSetupRemote = true

[pull]
	ff = only

# TODO: default for homebrew managed git on macOS is osxkeychain, investigate
# if this is safe to remove to make this file more portable (e.g. what
# happens on macOS if brew git is not used?) 
[credential]
	helper = osxkeychain

# Used for Google project authentication (e.g. go.googlesource.com and Gerrit)
# TODO: investigate migration to git config --local.
[http]
    cookiefile = ~/.gitcookies

[alias]
	amend = commit --amend -C HEAD
	smash = rebase --autosquash --committer-date-is-author-date
	log = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	dshow = -c diff.external=difft show --ext-diff
    difft = -c diff.external=difft diff

